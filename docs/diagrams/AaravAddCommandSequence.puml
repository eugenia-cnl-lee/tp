@startuml
actor User
participant ":InternTrackr" as IT
participant ":Parser" as P
participant ":AddCommandParser" as ACP
participant ":AddCommand" as AC
participant "newApp:Application" as APP
participant ":ApplicationList" as AL
participant ":Ui" as UI
participant ":Storage" as S

User -> IT : run("add c/Google r/SWE")
IT -> P : parse(fullCommand)
P -> ACP : parse(arguments)
ACP --> P : command
P --> IT : command

IT -> AC : execute(...)
AC -> APP : <<create>>
AC -> AL : hasApplication(newApp)

alt duplicate found
    AL --> AC : true
    AC -> UI : showMessage(duplicate warning)
    UI --> User : duplicate warning
else no duplicate
    AL --> AC : false
    AC -> AL : addApplication(newApp)
    AC -> UI : showMessage(confirmation)
    UI --> User : confirmation message
    AC -> S : save(...)
end
@enduml
