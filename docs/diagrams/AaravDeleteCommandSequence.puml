@startuml
actor User
participant ":InternTrackr" as IT
participant ":Parser" as P
participant ":DeleteCommandParser" as DCP
participant ":DeleteCommand" as DC
participant ":ApplicationList" as AL
participant ":Ui" as UI
participant ":Storage" as S

User -> IT : run("delete 2") or run("delete archive 1")
IT -> P : parse(arguments)
P -> DCP : parse(arguments)
note right of DCP
  Detects optional "archive" keyword.
  Sets isArchived flag accordingly.
end note
DCP --> P : <<create>> DeleteCommand(index, isArchived)
P --> IT : command

alt isArchived = false (active deletion)
    IT -> DC : execute(...)
    DC -> AL : getActiveApplication(index)
else isArchived = true (archived deletion)
    IT -> DC : execute(...)
    DC -> AL : getArchivedApplication(index)
end
AL --> DC : appToRemove
note right of DC
  Linear scan by object identity
  to find backingIndex in full list.
end note
DC -> AL : deleteApplication(backingIndex)
DC -> AL : countActive()
AL --> DC : activeCount
DC -> UI : showMessage(confirmation)
UI --> User : confirmation message
DC -> S : save(...)
@enduml
