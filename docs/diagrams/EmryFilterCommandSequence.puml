@startuml
skinparam ParticipantPadding 20
skinparam BoxPadding 10

actor User
participant ":InternTrackr" as IT
participant ":Parser" as P
participant "c:FilterCommand" as FC
participant ":ApplicationList" as AL
participant "<<class>>\n:Application" as AppClass
participant "app:Application" as App
participant ":Ui" as UI

User -> IT : "filter Applied"
IT -> P : parseCommand("filter Applied")
activate P
create FC
P -> FC : FilterCommand("Applied")
P --> IT : c
deactivate P

IT -> FC : execute(applications, ui, storage)
activate FC

FC -> AppClass : isValidStatus("Applied")
activate AppClass
AppClass --> FC : true
deactivate AppClass

FC -> AppClass : getNormalizedStatus("Applied")
activate AppClass
AppClass --> FC : "Applied"
deactivate AppClass

FC -> AL : getSize()
activate AL
AL --> FC : size
deactivate AL

loop for each application (1 to size)
    FC -> AL : getApplication(i)
    activate AL
    AL --> FC : app
    deactivate AL

    FC -> App : isArchived()
    activate App
    App --> FC : false
    deactivate App

    FC -> App : getStatus()
    activate App
    App --> FC : "Applied"
    deactivate App

    alt status matches searchStatus
        FC -> UI : showMessage(displayIndex + ". " + app.toString())
        activate UI
        UI --> FC
        deactivate UI
    end
end

alt matchCount == 0
    FC -> UI : showMessage("No applications found...")
    activate UI
    UI --> FC
    deactivate UI
end

deactivate FC
@enduml
